APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Production: set APP_ENV=production and APP_DEBUG=false (never enable debug in production).
APP_DEBUG=false

# Sanctum API token lifetime in minutes (1440 = 24 hours). Leave empty only for local dev if needed.
SANCTUM_EXPIRATION=1440
APP_URL=http://localhost
APP_TIMEZONE=Asia/Kuwait

# Comma-separated browser origins allowed for CORS (no wildcards in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://abc-website-enhanced-wiys.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SMSBOX SMS Gateway (OTP)
SMSBOX_BASE_URL="http://smsbox.com/SMSGateway/Services/Messaging.asmx/Http_SendSMS"
SMSBOX_USERNAME=
SMSBOX_PASSWORD=
SMSBOX_CUSTOMER_ID=
SMSBOX_SENDER=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Octopus API: POST /api/octopus/orders — send Authorization: Bearer {token} or X-Access-Token
# Must start with abc_ followed by at least 32 random bytes (64 hex chars). Generate:
# php -r "echo 'abc_'.bin2hex(random_bytes(32)).PHP_EOL;"
OCTOPUS_API_TOKEN=

# Payment gateway mode: test (sandbox) or live (production)
PAYMENTS_MODE=test

# Ottu — test / sandbox credentials
OTTU_TEST_API_KEY=
OTTU_TEST_URL=https://sandbox.ottu.net
OTTU_TEST_HMAC_KEY=
OTTU_TEST_PG_CODE=credit-card
OTTU_TEST_SKIP_SIGNATURE_VERIFY=false

# Ottu — live / production credentials
# Use the domain only (https://payment.abcjuice.com) or the full checkout path — both work.
OTTU_LIVE_API_KEY=
OTTU_LIVE_URL=https://payment.abcjuice.com
OTTU_LIVE_HMAC_KEY=
OTTU_LIVE_PG_CODE=credit-card
OTTU_LIVE_SKIP_SIGNATURE_VERIFY=false

# Ottu website redirect URLs (shared for test and live)
OTTU_WEBSITE_RETURN_URL=https://abc-website-enhanced-wiys.vercel.app/en/payment/success
OTTU_WEBSITE_CANCEL_URL=https://abc-website-enhanced-wiys.vercel.app/en/payment/failed

# Upayments — test / sandbox credentials
UPAYMENTS_TEST_API_KEY=
UPAYMENTS_TEST_API_URL=https://sandboxapi.upayments.com/api/v1
UPAYMENTS_TEST_PAYMENT_GATEWAY_SRC=

# Upayments — live / production credentials
UPAYMENTS_LIVE_API_KEY=
UPAYMENTS_LIVE_API_URL=https://apiv2api.upayments.com/api/v1
UPAYMENTS_LIVE_PAYMENT_GATEWAY_SRC=create-invoice

# Legacy single-env keys still work as fallback when mode-specific keys are empty
# OTTU_API_KEY=
# OTTU_URL=https://sandbox.ottu.net
# OTTU_HMAC_KEY=
# UPAYMENTS_API_KEY=
# UPAYMENTS_API_URL=

NOTIFICATIONS_SEND_TO_ADMINS=false
NOTIFICATIONS_SEND_TO_FIREBASE=true
FIREBASE_CREDENTIALS_PATH=storage/firebase/abc.json

# --- Production deployment checklist (verify before go-live) ---
# [ ] APP_ENV=production
# [ ] APP_DEBUG=false
# [ ] SANCTUM_EXPIRATION=1440 (or your policy; do not leave tokens unlimited)
# [ ] APP_KEY set (php artisan key:generate)
# [ ] LOG_LEVEL=warning or error (not debug)
# [ ] CORS_ALLOWED_ORIGINS lists only real frontends (no *)
# [ ] OCTOPUS_API_TOKEN is a unique 32+ byte secret (not the old placeholder)
# [ ] OTTU_SKIP_SIGNATURE_VERIFY=false
# [ ] ERP_* and WAREHOUSE_STOCK_* credentials set (no defaults in config)
# [ ] php artisan config:cache after .env changes
